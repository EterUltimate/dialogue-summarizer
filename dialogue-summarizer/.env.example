# 对话总结系统配置文件
# 复制此文件为 .env 并根据需要修改

# ============ 后端选择 ============
# 可选: ollama, openai
DIALOGUE_BACKEND=ollama

# ============ Ollama 配置 ============
# Ollama 服务地址
OLLAMA_BASE_URL=http://localhost:11434

# Embedding 模型 (推荐: nomic-embed-text, mxbai-embed-large)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Rerank 模型 (可选)
# OLLAMA_RERANK_MODEL=

# LLM 模型 (推荐: qwen2.5:7b, llama3.1:8b, mistral:7b)
OLLAMA_LLM_MODEL=qwen2.5:7b

# ============ OpenAI API 配置 ============
# API 密钥
OPENAI_API_KEY=your-api-key-here

# API 基础URL (支持兼容的第三方API)
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding 模型
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM 模型
OPENAI_LLM_MODEL=gpt-4o-mini

# ============ 向量数据库配置 ============
# 可选: chroma, faiss, simple
VECTORDB_TYPE=chroma

# 持久化目录
VECTORDB_PERSIST_DIR=./data/vectordb
